{
  "name": "electropi-food-ordering",
  "version": "1.0.0",
  "description": "Online Food Ordering Web Application - MERN Stack",
  "scripts": {
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node backend/seed/seedData.js",
    "install-all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
